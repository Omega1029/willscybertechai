modules = ["nodejs-20", "web", "python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AI Agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AG-UI Frontend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "AI Agent"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd retail-ai-agent && PYTHONPATH=. python app/frontend/backend/main.py"
waitForPort = 8000

[[workflows.workflow]]
name = "AG-UI Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd retail-ai-agent/app/frontend && npm run dev -- -p 3000 -H 0.0.0.0"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
build = ["bash", "-c", "npm run build && cd retail-ai-agent/app/frontend && npm run build"]
publicDir = "dist"
run = ["bash", "-c", "cd retail-ai-agent && PYTHONPATH=. python app/frontend/backend/main.py & cd retail-ai-agent/app/frontend && npm start -- -p 3000 -H 0.0.0.0 & node server.js"]

[userenv]

